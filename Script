getgenv().FlySpeed = 50

getgenv().DoorBypass = false
getgenv().ESPEnabled = false
getgenv().ESPFilter = "All"

-- [[ FLIGHT & NOCLIP CORE ]]
RunService.Stepped:Connect(function()
    if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local HRP = LocalPlayer.Character.HumanoidRootPart
        local Hum = LocalPlayer.Character:FindFirstChildOfClass("Humanoid")

        -- Noclip Physics Overwrite
        if getgenv().Noclip or getgenv().FlyEnabled then
            for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
                if v:IsA("BasePart") then v.CanCollide = false end
            end
        end

        -- Active Flight Logic
        if getgenv().FlyEnabled then
            Hum.PlatformStand = true -- Prevents walking animations from breaking flight
            local Direction = Vector3.new(0, 0, 0)

            if UserInputService:IsKeyDown(Enum.KeyCode.W) then Direction = Direction + Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then Direction = Direction - Camera.CFrame.LookVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then Direction = Direction - Camera.CFrame.RightVector end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then Direction = Direction + Camera.CFrame.RightVector end

            HRP.Velocity = Direction * getgenv().FlySpeed
            -- Keep character upright while flying
            HRP.CFrame = CFrame.new(HRP.Position, HRP.Position + Camera.CFrame.LookVector)
        else
            if Hum.PlatformStand then Hum.PlatformStand = false end
        end
    end
end)

-- [[ AIMBOT & VISUALS ]]
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 2
FOVCircle.Filled = false

local function GetClosestPlayer()
    local Target = nil
    local ShortestDistance = getgenv().AimbotFOV
    local MyRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not MyRoot then return nil end

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(getgenv().TargetPart) then
            local pTeam = v.Team and v.Team.Name or "None"
            if getgenv().TargetFilter ~= "All" and pTeam ~= getgenv().TargetFilter then continue end
            
            local Part = v.Character[getgenv().TargetPart]
            if (Part.Position - MyRoot.Position).Magnitude > getgenv().MaxAimDistance then continue end

            local Pos, OnScreen = Camera:WorldToViewportPoint(Part.Position)
            if OnScreen then
                local ScreenDist = (Vector2.new(Pos.X, Pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if ScreenDist < ShortestDistance then
                    Target = Part
                    ShortestDistance = ScreenDist
                end
            end
        end
    end
    return Target
end

RunService.RenderStepped:Connect(function()
    if getgenv().Aimbot then
        local Target = GetClosestPlayer()
        if Target then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, Target.Position), 0.5)
        end
    end
    FOVCircle.Visible = getgenv().ShowFOV
    FOVCircle.Radius = getgenv().AimbotFOV
    FOVCircle.Color = getgenv().FOVColor
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
end)

