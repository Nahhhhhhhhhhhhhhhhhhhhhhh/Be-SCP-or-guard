local Camera = workspace.CurrentCamera

-- CONFIG GLOBALS
getgenv().Aimbot = false
getgenv().ShowFOV = false
getgenv().AimbotFOV = 150
getgenv().FOVColor = Color3.fromRGB(0, 255, 255)
getgenv().TargetPart = "Head"
getgenv().TargetFilter = "All"
getgenv().AimbotSmoothing = 1
getgenv().CustomSpeed = 16 
getgenv().Noclip = false
getgenv().FlyEnabled = false
getgenv().DoorBypass = false
getgenv().ESPEnabled = false
getgenv().ESPFilter = "All" -- NEW: ESP Team Filter
getgenv().ESPMode = "Highlights"

-- =========================
-- AIMBOT & TARGETING
-- =========================
local function GetClosestPlayer()
    local Target = nil
    local ShortestDistance = getgenv().AimbotFOV
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(getgenv().TargetPart) then
            -- Aimbot Filter
            local pTeam = v.Team and v.Team.Name or "None"
            if getgenv().TargetFilter ~= "All" and pTeam ~= getgenv().TargetFilter then continue end

            local Part = v.Character[getgenv().TargetPart]
            local Pos, OnScreen = Camera:WorldToViewportPoint(Part.Position)
            if OnScreen then
                local Distance = (Vector2.new(Pos.X, Pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if Distance < ShortestDistance then
                    Target = Part
                    ShortestDistance = Distance
                end
            end
        end
    end
    return Target
end

-- =========================
-- DYNAMIC ESP (With Team Filter)
-- =========================
local function UpdateESP()
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local highlight = p.Character:FindFirstChild("Zenhub_Highlight")
            local pTeam = p.Team and p.Team.Name or "None"
            
            -- Filter Logic
            local matchesFilter = (getgenv().ESPFilter == "All") or (pTeam == getgenv().ESPFilter)
            
            if getgenv().ESPEnabled and matchesFilter then
                if not highlight then
                    highlight = Instance.new("Highlight", p.Character)
                    highlight.Name = "Zenhub_Highlight"
                end
                highlight.Enabled = true
                highlight.FillColor = p.TeamColor.Color
                highlight.FillTransparency = (getgenv().ESPMode == "Box") and 1 or 0.5
                highlight.OutlineColor = (getgenv().ESPMode == "Box") and p.TeamColor.Color or Color3.new(1,1,1)
            elseif highlight then
                highlight.Enabled = false
            end
        end
    end
end

-- =========================
-- UTILITIES & RUNTIME
-- =========================
task.spawn(function()
    while task.wait(0.2) do
        UpdateESP() -- Refresh ESP Filters
        if getgenv().DoorBypass and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("ClickDetector") and (v.Parent.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude < 15 then
                    fireclickdetector(v)
                end
            end
        end
    end
end)

local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 2
FOVCircle.Filled = false

RunService.RenderStepped:Connect(function()
    if getgenv().Aimbot then
        local Target = GetClosestPlayer()
        if Target then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, Target.Position), 1 / getgenv().AimbotSmoothing)
        end
    end
    FOVCircle.Visible = getgenv().ShowFOV
    FOVCircle.Radius = getgenv().AimbotFOV
    FOVCircle.Color = getgenv().FOVColor
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)
end)

