-- Utility: Get Closest Player
local function GetClosestToMouse()
    local Target = nil
    local MaxDist = getgenv().AimbotFOV
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("HumanoidRootPart") then
            local Pos, OnScreen = Camera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
            if OnScreen then
                local Dist = (Vector2.new(Pos.X, Pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                if Dist < MaxDist then
                    Target = v
                    MaxDist = Dist
                end
            end
        end
    end
    return Target
end

-- ESP Logic
local function ApplyESP(player)
    if player == LocalPlayer then return end
    local function setupESPOnChar(char)
        if not char then return end
        local head = char:WaitForChild("Head", 5)
        if not head then return end

        if char:FindFirstChild("ESPHighlight") then char.ESPHighlight:Destroy() end
        if head:FindFirstChild("ESPNameTag") then head.ESPNameTag:Destroy() end

        if ESP_Config.Enabled then
            local highlight = Instance.new("Highlight")
            highlight.Name = "ESPHighlight"
            highlight.Parent = char
            highlight.FillTransparency = ESP_Config.HighlightTransparency
            if player.Team then highlight.FillColor = player.TeamColor.Color end

            if ESP_Config.ShowNames then
                local bgui = Instance.new("BillboardGui", head)
                bgui.Name = "ESPNameTag"
                bgui.Size = UDim2.new(0, 100, 0, 50)
                bgui.StudsOffset = Vector3.new(0, 2.5, 0)
                bgui.AlwaysOnTop = true

                local label = Instance.new("TextLabel", bgui)
                label.BackgroundTransparency = 1
                label.Size = UDim2.new(1, 0, 1, 0)
                label.Text = player.DisplayName or player.Name
                label.TextColor3 = Color3.new(1, 1, 1)
                label.TextStrokeTransparency = 0
                label.Font = Enum.Font.SourceSansBold
                label.TextSize = ESP_Config.NameScale
            end
        end
    end
    player.CharacterAdded:Connect(setupESPOnChar)
    if player.Character then setupESPOnChar(player.Character) end
end

local function RefreshCurrentESP()
    for _, p in pairs(Players:GetPlayers()) do ApplyESP(p) end
end

-- Metatable Hook for Silent Aim
local mt = getrawmetatable(game)
local old = mt.__index
setreadonly(mt, false)
mt.__index = newcclosure(function(t, k)
    if k == "Hit" and getgenv().SilentAim then
        local Target = GetClosestToMouse()
        if Target then return Target.Character.HumanoidRootPart.CFrame end
    end
    return old(t, k)
end)
setreadonly(mt, true)

-- Main Loops (Aimbot & NoClip)
RunService.RenderStepped:Connect(function()
    FOVCircle.Visible = getgenv().ShowFOV
    FOVCircle.Radius = getgenv().AimbotFOV
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

    if getgenv().Aimbot then
        local Target = GetClosestToMouse()
        if Target and Target.Character and Target.Character:FindFirstChild("Head") then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, Target.Character.Head.Position)
        end
    end
    
    if getgenv().Noclip and LocalPlayer.Character then
        for _, v in pairs(LocalPlayer.Character:GetDescendants()) do
            if v:IsA("BasePart") then v.CanCollide = false end
        end
    end
end)

