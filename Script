local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera
local RunService = game:GetService("RunService")

-- CONFIG
getgenv().Aimbot = false
getgenv().AimbotTeamCheck = false
getgenv().ShowFOV = false
getgenv().AimbotFOV = 150
getgenv().TargetPart = "Head" 
getgenv().MaxDistance = 500 

local ESP_Config = {
    Enabled = false,
    ShowGuards = true,
    ShowSCPs = true,
    ShowClassD = true
}

-- FOV Circle
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 1.5
FOVCircle.Color = Color3.fromRGB(255, 255, 255)
FOVCircle.Transparency = 0.8
FOVCircle.Filled = false

-- TARGETING ENGINE
local function GetClosestTarget()
    local Target = nil
    local MaxDistFOV = getgenv().AimbotFOV
    if not LocalPlayer.Character or not LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then return nil end
    local MyPos = LocalPlayer.Character.HumanoidRootPart.Position

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
            if getgenv().AimbotTeamCheck and v.Team == LocalPlayer.Team then continue end

            local Part = v.Character:FindFirstChild(getgenv().TargetPart)
            if Part then
                local WorldDist = (Part.Position - MyPos).Magnitude
                if WorldDist <= getgenv().MaxDistance then
                    local Pos, OnScreen = Camera:WorldToViewportPoint(Part.Position)
                    if OnScreen then
                        local ScreenDist = (Vector2.new(Pos.X, Pos.Y) - Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)).Magnitude
                        if ScreenDist < MaxDistFOV then
                            Target = v
                            MaxDistFOV = ScreenDist
                        end
                    end
                end
            end
        end
    end
    return Target
end

-- RUNTIME
RunService.RenderStepped:Connect(function()
    FOVCircle.Visible = getgenv().ShowFOV
    FOVCircle.Radius = getgenv().AimbotFOV
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

    if getgenv().Aimbot then
        local Target = GetClosestTarget()
        if Target and Target.Character and Target.Character:FindFirstChild(getgenv().TargetPart) then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, Target.Character[getgenv().TargetPart].Position)
        end
    end

    -- ESP Refresh
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local highlight = p.Character:FindFirstChild("ESP_Highlight")
            local teamName = p.Team and p.Team.Name or "None"
            
            local shouldShow = false
            if ESP_Config.Enabled then
                if (teamName == "Guard" or teamName == "Security") and ESP_Config.ShowGuards then shouldShow = true
                elseif teamName == "SCP" and ESP_Config.ShowSCPs then shouldShow = true
                elseif (teamName == "Class-D" or teamName == "Prisoner") and ESP_Config.ShowClassD then shouldShow = true
                elseif not ESP_Config.ShowGuards and not ESP_Config.ShowSCPs and not ESP_Config.ShowClassD then shouldShow = true end
            end

            if shouldShow then
                if not highlight then
                    highlight = Instance.new("Highlight", p.Character)
                    highlight.Name = "ESP_Highlight"
                end
                highlight.Enabled = true
                highlight.FillColor = p.TeamColor.Color
            elseif highlight then
                highlight.Enabled = false
            end
        end
    end
end)

