-- [[ ESP & BYPASS RUNTIME LOOP ]]
task.spawn(function()
    while task.wait(0.2) do
        -- ESP Refresh
        for _, p in pairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and p.Character then
                local hl = p.Character:FindFirstChild("Zenhub_Highlight")
                local pTeam = p.Team and p.Team.Name or "None"
                local matches = (getgenv().ESPFilter == "All") or (pTeam == getgenv().ESPFilter)
                if getgenv().ESPEnabled and matches then
                    if not hl then hl = Instance.new("Highlight", p.Character); hl.Name = "Zenhub_Highlight" end
                    hl.Enabled = true; hl.FillColor = p.TeamColor.Color
                    hl.FillTransparency = (getgenv().ESPMode == "Box") and 1 or 0.5
                elseif hl then hl.Enabled = false end
            end
        end
        -- Door Bypass
        if getgenv().DoorBypass and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("ClickDetector") and (v.Parent.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude < 15 then
                    fireclickdetector(v)
                end
            end
        end
    end
end)
