local Rayfield = loadstring(game:HttpGet("https://sirius.menu/rayfield"))()
local Players = game:GetService("Players")
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local Lighting = game:GetService("Lighting")
local LocalPlayer = Players.LocalPlayer
local Camera = workspace.CurrentCamera

-- CONFIG GLOBALS
getgenv().Aimbot = false
getgenv().ShowFOV = false
getgenv().AimbotFOV = 150
getgenv().FOVColor = Color3.fromRGB(0, 255, 255)
getgenv().TargetPart = "Head"
getgenv().CustomSpeed = 16 
getgenv().Noclip = false
getgenv().FlyEnabled = false
getgenv().FlySpeed = 50
getgenv().DoorBypass = false
getgenv().ESPEnabled = false

-- =========================
-- FIXED AUTO-DOOR BYPASS (Button Detection)
-- =========================
task.spawn(function()
    while task.wait(0.3) do
        if getgenv().DoorBypass and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
            for _, v in pairs(workspace:GetDescendants()) do
                -- Specifically looks for buttons or clickable parts near doors
                if v:IsA("ClickDetector") then
                    local parent = v.Parent
                    if parent and (parent.Name:lower():find("button") or parent.Name:lower():find("keypad") or parent.Name:lower():find("scanner")) then
                        local dist = (parent.Position - LocalPlayer.Character.HumanoidRootPart.Position).Magnitude
                        if dist < 12 then
                            fireclickdetector(v)
                        end
                    end
                end
            end
        end
    end
end)

-- =========================
-- PERSISTENCE MODULE
-- =========================
LocalPlayer.CharacterAdded:Connect(function(char)
    local hum = char:WaitForChild("Humanoid", 10)
    hum.WalkSpeed = getgenv().CustomSpeed
end)

-- =========================
-- FLIGHT & VISUAL ENGINE
-- =========================
local FOVCircle = Drawing.new("Circle")
FOVCircle.Thickness = 2
FOVCircle.Filled = false 
FOVCircle.Visible = false

local BodyGyro = Instance.new("BodyGyro")
local BodyVelocity = Instance.new("BodyVelocity")
BodyGyro.P = 9e4
BodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)

RunService.RenderStepped:Connect(function()
    -- Flight
    if getgenv().FlyEnabled and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart") then
        local HRP = LocalPlayer.Character.HumanoidRootPart
        BodyGyro.Parent = HRP; BodyVelocity.Parent = HRP
        BodyGyro.CFrame = Camera.CFrame
        local Direction = Vector3.new(0,0,0)
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then Direction = Direction + Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then Direction = Direction - Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then Direction = Direction - Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then Direction = Direction + Camera.CFrame.RightVector end
        BodyVelocity.Velocity = Direction * getgenv().FlySpeed
    else
        BodyGyro.Parent = nil; BodyVelocity.Parent = nil
    end

    -- FOV Update
    FOVCircle.Visible = getgenv().ShowFOV
    FOVCircle.Radius = getgenv().AimbotFOV
    FOVCircle.Color = getgenv().FOVColor
    FOVCircle.Position = Vector2.new(Camera.ViewportSize.X/2, Camera.ViewportSize.Y/2)

    -- ESP
    for _, p in pairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and p.Character then
            local highlight = p.Character:FindFirstChild("ESP_Highlight")
            if getgenv().ESPEnabled then
                if not highlight then
                    highlight = Instance.new("Highlight", p.Character)
                    highlight.Name = "ESP_Highlight"
                end
                highlight.Enabled = true
                highlight.FillColor = p.TeamColor.Color
            elseif highlight then highlight.Enabled = false end
        end
    end
end)

